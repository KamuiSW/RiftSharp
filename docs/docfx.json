{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "../src/RiftSharp/RiftSharp.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "RiftSharp",
      "_appTitle": "RiftSharp Documentation",
      "_enableSearch": true,
      "_disableContribution": false
    }
  }
}